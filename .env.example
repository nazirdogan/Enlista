# Subscription plans (create recurring monthly prices in Stripe Dashboard)
STRIPE_PRICE_PLUS=price_...     # $25/month · 5 credits
STRIPE_PRICE_PRO=price_...      # $40/month · 15 credits

# One-time credit pack prices (create one-time prices in Stripe Dashboard)
STRIPE_PRICE_CREDITS_5=price_... # $15 one-time · 5 extra credits
STRIPE_PRICE_CREDITS_10=price_.. # $25 one-time · 10 extra credits
STRIPE_PRICE_CREDITS_20=price_.. # $40 one-time · 20 extra credits

# Legacy plan IDs (kept for backward compat — no longer used for new signups)
STRIPE_PRICE_SOLO=price_...
STRIPE_PRICE_BOUTIQUE=price_...
STRIPE_PRICE_AGENCY=price_...
